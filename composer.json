{
    "name": "rbaezc/hexagenphp-framework",
    "description": "HexaGen PHP Framework - A lightweight, vertical slice framework optimized for FrankenPHP",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/mailer": "^7.0",
        "twig/twig": "^3.0",
        "predis/predis": "^2.0",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.23",
        "psy/psysh": "^0.12"
    },
    "suggest": {
        "aws/aws-sdk-php": "Required for the S3 storage driver (^3.0)",
        "ext-pcntl": "Required for graceful schedule:work daemon shutdown"
    },
    "autoload": {
        "files": [
            "src/Core/Helpers.php"
        ],
        "psr-4": {
            "HexaGen\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}

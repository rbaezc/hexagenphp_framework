# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────

APP_NAME="HexaGen App"
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:8000

# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=change-me-to-a-random-64-hex-char-string

APP_HTTPS=false
APP_TIMEZONE=UTC
APP_LOCALE=en

# Custom Content-Security-Policy. Leave empty to use the default restrictive policy.
# APP_CSP=default-src 'self'

# ─────────────────────────────────────────
# CORS  (config/cors.php)
# ─────────────────────────────────────────

# Comma-separated allowed origins. Use * only for fully public APIs.
CORS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────

# SQLite (default):  sqlite:database/hexagen.sqlite
# MySQL:             mysql:host=127.0.0.1;port=3306;dbname=hexagen;charset=utf8mb4
# PostgreSQL:        pgsql:host=127.0.0.1;port=5432;dbname=hexagen
DB_DSN=sqlite:database/hexagen.sqlite
DB_USER=
DB_PASSWORD=

# ─────────────────────────────────────────
# Mail
# ─────────────────────────────────────────

MAIL_DRIVER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# SMTP (MAIL_DRIVER=smtp)
MAIL_HOST=smtp.mailpit.example
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# ─────────────────────────────────────────
# Filesystem / Storage
# ─────────────────────────────────────────

FILESYSTEM_DISK=local

# AWS S3 (FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

# ─────────────────────────────────────────
# Queue
# ─────────────────────────────────────────

QUEUE_DRIVER=sync

# ─────────────────────────────────────────
# Broadcasting
# ─────────────────────────────────────────

BROADCAST_DRIVER=sse

# ─────────────────────────────────────────
# Cache
# ─────────────────────────────────────────

CACHE_DRIVER=file

# ─────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────

# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-to-a-random-secret
